{
    "name": "dokumentationsgenerator",
    "version": "snapshot-1.4.0",
    "private": false,
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "start:e2e": "ng run dokumentationsgenerator:serve-coverage:local",
        "build": "ng build",
        "watch": "ng build --watch",
        "test": "ng test",
        "test:unit": "ng test --code-coverage --watch false",
        "lint": "ng lint",
        "lint:fix": "ng lint --fix",
        "e2e:ci": "start-server-and-test start:e2e http://localhost:4200/dokumentationsgenerator_local/#/ cy:run",
        "e2e:coverage": "npx nyc report --reporter=lcov --reporter=text-summary",
        "cy:open": "cypress open",
        "cy:run": "cypress run --browser /opt/google/chrome/google-chrome.e2e --headless --quiet",
        "postcy:run": "npm run e2e:coverage",
        "update:dependencies": "npx npm-check-updates -u"
    },
    "dependencies": {
        "@angular/animations": "20.3.10",
        "@angular/cdk": "20.2.12",
        "@angular/common": "20.3.10",
        "@angular/compiler": "20.3.10",
        "@angular/core": "20.3.10",
        "@angular/forms": "20.3.10",
        "@angular/material": "20.2.12",
        "@angular/platform-browser": "20.3.10",
        "@angular/platform-browser-dynamic": "20.3.10",
        "@angular/router": "20.3.10",
        "marked": "^16.4.2",
        "ngx-markdown": "20.1.0",
        "mermaid": "^11.12.0",
        "prismjs": "^1.30.0",
        "rxjs": "7.8.1"
    },
    "devDependencies": {
        "@angular-builders/custom-webpack": "20.0.0",
        "@angular-devkit/build-angular": "20.3.10",
        "@angular-eslint/builder": "20.6.0",
        "@angular-eslint/eslint-plugin": "^20.6.0",
        "@angular-eslint/eslint-plugin-template": "20.6.0",
        "@angular-eslint/schematics": "20.6.0",
        "@angular-eslint/template-parser": "^20.6.0",
        "@angular/cli": "20.3.10",
        "@angular/compiler-cli": "20.3.10",
        "@cypress/code-coverage": "3.12.29",
        "@cypress/schematic": "2.5.1",
        "@istanbuljs/nyc-config-typescript": "1.0.2",
        "@jsdevtools/coverage-istanbul-loader": "3.0.5",
        "@types/jasmine": "5.1.4",
        "@typescript-eslint/eslint-plugin": "^8.47.0",
        "@typescript-eslint/parser": "^8.47.0",
        "cypress": "13.6.6",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "istanbul-lib-coverage": "3.2.2",
        "jasmine-core": "5.1.2",
        "karma": "6.4.3",
        "karma-chrome-launcher": "3.2.0",
        "karma-coverage": "2.2.1",
        "karma-jasmine": "5.1.0",
        "karma-jasmine-html-reporter": "2.1.0",
        "nyc": "15.1.0",
        "prettier": "^3.2.5",
        "start-server-and-test": "2.0.3",
        "typescript": "5.8.3"
    },
    "engines": {
        "npm": ">=10.1.0",
        "node": ">=24.0.0"
    }
}
